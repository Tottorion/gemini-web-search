{
  "manifest_version": 3,
  "name": "Gemini 最新情報スイッチ",
  "version": "1.0.1",
  "description": "Geminiに「Webを検索」チェックを追加し、必要なときだけWeb上の最新情報を調べるよう促します。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
